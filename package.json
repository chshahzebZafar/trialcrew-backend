{
  "name": "trialcrew-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "prisma generate && tsc",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx scripts/local-test.ts",
    "test:sweep": "tsx scripts/sweep-test.ts",
    "test:pg": "tsx scripts/pg-test.ts",
    "db:fast-forward": "tsx scripts/fast-forward-cycle.ts",
    "check:contract": "node scripts/check-contract.mjs",
    "verify": "npm run typecheck && npm run check:contract && npm run test:e2e",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@clerk/backend": "^3.8.1",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.1.0",
    "fastify": "^5.1.0",
    "pg-boss": "^12.20.0",
    "prisma": "^6.1.0",
    "svix": "^1.96.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
