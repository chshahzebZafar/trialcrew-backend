# Server
PORT=4000
HOST=0.0.0.0

# Database (for the Prisma/Postgres adoption — see prisma/schema.prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trialcrew?schema=public"

# Auth (Clerk) — not required for the in-memory demo store
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Storage (Cloudflare R2, S3-compatible) — for Day-0 proof uploads.
# Leave unset to keep proof upload inert (the app falls back to the local image).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=          # public base url for the bucket, e.g. https://proofs.yourdomain.com
